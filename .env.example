# HarcApp - Zmienne środowiskowe
# Skopiuj ten plik jako .env i dostosuj wartości

# =====================================================
# PostgreSQL Database
# =====================================================
POSTGRES_USER=harcapp
POSTGRES_PASSWORD=harcapp_secret
POSTGRES_DB=harcapp_db
POSTGRES_PORT=5433

# =====================================================
# pgAdmin (panel administracyjny bazy danych)
# =====================================================
PGADMIN_DEFAULT_EMAIL=admin@harcapp.pl
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_PORT=5050

# =====================================================
# Aplikacja
# =====================================================
APP_PORT=8080
APP_ENV=development
APP_DEBUG=true
